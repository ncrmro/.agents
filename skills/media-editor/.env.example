# Copy to `.env` (gitignored) and fill in. Loaded by devenv (dotenv) and by
# scripts/deps-doctor.sh. Never commit the real .env.

# Hugging Face token for whisperx --diarize (pyannote weights are gated).
# Create at https://hf.co/settings/tokens and accept the terms at
# https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Optional overrides (defaults shown):
# OLLAMA_HOST=http://localhost:11434
# NEMOTRON_MODEL=nemotron-3-nano
# WHISPER_MODEL_DIR=~/.cache/whisper
